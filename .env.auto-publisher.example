# ============================================
# AUTO-PUBLISHER ENVIRONMENT VARIABLES
# ============================================
# Add these to your Vercel project settings (Settings -> Environment Variables)

# OpenRouter AI (get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-PASTE-YOUR-KEY-HERE
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Cron Security (Vercel sends this in Authorization header)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=PASTE-RANDOM-32-BYTE-HEX-HERE

# Publishing Behavior
AUTO_PUBLISH_ARTICLES_PER_DAY=5
AUTO_PUBLISH_DRY_RUN=false

# Quality Gates (traffic-safety thresholds)
MIN_WORD_COUNT=1500
MIN_SEO_SCORE=70
MAX_AI_DETECTION=0.6

# Monetag Zone IDs (from your AGENTS.md)
MONETAG_BANNER_ZONE=29505513
MONETAG_IN_ARTICLE_ZONE=11103150
MONETAG_SIDEBAR_ZONE=29505514
MONETAG_POPUNDER_ZONE=29505515
MONETAG_INTERSTITIAL_ZONE=29505516

# Schedule (cron syntax, default 8 AM daily)
# Format: minute hour day month weekday
# 0 8 * * * = 8:00 AM every day
# 0 */6 * * * = every 6 hours
# 0 8,20 * * * = 8 AM and 8 PM
CRON_SCHEDULE=0 8 * * *
