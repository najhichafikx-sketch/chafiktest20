# Chafiktech Auto-Publisher — environment variables
# Copy this to .env.local and fill in real values
# Docs: see lib/auto-publisher/README.md

# ---- Required ----
OPENROUTER_API_KEY=sk-or-v1-xxxxx
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx
CRON_SECRET=<generate-with-node-crypto-randomBytes-32-bytes>

# ---- Pipeline control ----
AUTO_PUBLISH_ARTICLES_PER_DAY=5
AUTO_PUBLISH_WC_COUNT=3
AUTO_PUBLISH_INTERVAL_HOURS=4
AUTO_PUBLISH_DRY_RUN=false
# Languages to publish in (comma-separated). Default: en,ar,fr
AUTO_PUBLISH_LANGUAGES=en,ar,fr

# ---- Quality gates ----
MIN_WORD_COUNT=1500
MIN_SEO_SCORE=70
MAX_AI_DETECTION=0.6
MAX_KEYWORD_DENSITY=0.025
MIN_FAQ_ANSWER_CHARS=200

# ---- AI model ----
# Default chain (in order): OPENROUTER_MODEL -> gpt-4o-mini -> llama-3.3-70b -> mistral-7b
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ---- Monetag zone IDs (from public/ads.txt) ----
MONETAG_BANNER_ZONE=29505513
MONETAG_IN_ARTICLE_ZONE=11103150
MONETAG_SIDEBAR_ZONE=29505514
MONETAG_POPUNDER_ZONE=29505515
MONETAG_INTERSTITIAL_ZONE=29505516

# ---- Misc ----
SITE_URL=https://www.chafiktech.com
NEXT_PUBLIC_SITE_URL=https://www.chafiktech.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
