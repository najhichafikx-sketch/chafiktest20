  <!-- Toast -->
  <div class="aih-toast" id="aih-toast">
    <span>✅</span><span id="aih-toast-msg">Done!</span>
  </div>

  <script src="../js/app.js"></script>
  <script src="../js/AdManager.js"></script>
  <script src="../js/saas-ux.js"></script>
  <script>
  // ================================================================
  //  AI Content Detector & Humanizer — Logic
  // ================================================================

  const DETECT_MSGS = [
    "Analyzing writing patterns...",
    "Detecting AI signals...",
    "Evaluating sentence structure...",
    "Measuring content originality...",
    "Generating report..."
  ];
  const HUMANIZE_MSGS = [
    "Rewriting naturally...",
    "Improving readability...",
    "Adding human flow...",
    "Enhancing engagement...",
    "Finalizing content..."
  ];
  const SEO_MSGS = [
    "Analyzing article structure...",
    "Identifying SEO keywords...",
    "Humanizing content flow...",
    "Optimizing headings...",
    "Finalizing SEO article..."
  ];

  // State
  let detectResult = null;
  let humanizeResult = null;
  let detectInput = '';

  // ---- Utilities ----
  function updateCharCount(el, countId) {
    document.getElementById(countId).textContent = el.value.length + ' characters';
  }

  function showToast(msg) {
    const t = document.getElementById('aih-toast');
    document.getElementById('aih-toast-msg').textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2800);
  }

  function copyText(text) {
    navigator.clipboard.writeText(text).then(() => showToast('Copied to clipboard!'));
  }

  function downloadFile(content, filename, type) {
    const blob = new Blob([content], { type });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = filename; a.click();
    showToast('File downloaded!');
  }

  // ---- Tab switching ----
  function switchTab(name) {
    document.querySelectorAll('.aih-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.aih-panel').forEach(p => p.classList.remove('active'));
    document.querySelector(`[data-panel="${name}"]`).classList.add('active');
    document.getElementById(`panel-${name}`).classList.add('active');
  }

  document.getElementById('aih-tabs').addEventListener('click', e => {
    const btn = e.target.closest('.aih-tab');
    if (!btn) return;
    switchTab(btn.dataset.panel);

    // Auto-populate compare if both results exist
    if (btn.dataset.panel === 'compare') populateCompare();
  });

  // ---- Loading animation helper ----
  function runLoader(msgs, barId, msgId, duration, callback) {
    const bar = document.getElementById(barId);
    const msgEl = document.getElementById(msgId);
    let step = 0;
    bar.style.width = '0%';
    const interval = setInterval(() => {
      step++;
      bar.style.width = Math.min((step / msgs.length) * 100, 95) + '%';
      msgEl.textContent = msgs[Math.min(step - 1, msgs.length - 1)];
    }, duration / msgs.length);
    setTimeout(() => {
      clearInterval(interval);
      bar.style.width = '100%';
      msgEl.textContent = '✅ Done!';
      setTimeout(callback, 350);
    }, duration);
  }

  // ================================================================
  //  TOOL 1: AI DETECTOR
  // ================================================================

  function analyzeAI(text) {
    // Heuristic analysis engine
    const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
    const words = text.split(/\s+/).filter(Boolean);
    const avgWords = words.length / Math.max(sentences.length, 1);

    // AI signals
    let aiScore = 0;
    let signals = [];

    // 1. Sentence length uniformity (AI tends to be uniform)
    const lengths = sentences.map(s => s.split(/\s+/).length);
    const variance = lengths.reduce((acc, l) => acc + Math.pow(l - avgWords, 2), 0) / lengths.length;
    const variationScore = Math.min(100, Math.round(variance * 3));
    if (variance < 8) { aiScore += 25; signals.push('low_variation'); }

    // 2. Repetitive phrase detection
    const wordCounts = {};
    words.forEach(w => { const lw = w.toLowerCase().replace(/[^a-z]/g,''); wordCounts[lw] = (wordCounts[lw]||0)+1; });
    const topWords = Object.entries(wordCounts).sort((a,b)=>b[1]-a[1]).slice(0,5);
    const repScore = topWords.filter(([w,c]) => w.length > 4 && c > 3).length;
    if (repScore > 2) { aiScore += 20; signals.push('repetition'); }
    const repetitionScore = Math.max(0, 100 - repScore * 15);

    // 3. Formal/robotic phrases
    const aiPhrases = ['furthermore','moreover','in conclusion','it is important to','in addition','it should be noted','this ensures','this allows','as a result','consequently','therefore','thus','utilize','leverage','streamline','delve into','it is worth noting'];
    const foundPhrases = aiPhrases.filter(p => text.toLowerCase().includes(p));
    if (foundPhrases.length > 2) { aiScore += 20; signals.push('formal_phrases'); }

    // 4. Average sentence complexity
    const avgLen = avgWords;
    if (avgLen > 20 && avgLen < 35) { aiScore += 15; signals.push('uniform_length'); }

    // 5. Contractions (humans use them more)
    const contractions = (text.match(/\b(don't|can't|won't|isn't|aren't|it's|I'm|you're|we're|they're|I've|you've|I'll)\b/gi) || []).length;
    const hasFirstPerson = /\b(I|me|my|we|our)\b/i.test(text);
    if (contractions < 2 && !hasFirstPerson) aiScore += 15;

    // Clamp
    aiScore = Math.min(95, Math.max(5, aiScore + Math.round(Math.random() * 8)));
    const humanScore = 100 - aiScore;

    // Sentence classification
    const classifiedSentences = sentences.map(s => {
      const sLen = s.split(/\s+/).length;
      const hasAiPhrase = aiPhrases.some(p => s.toLowerCase().includes(p));
      const isAI = hasAiPhrase || (sLen > 22 && sLen < 38);
      return { text: s.trim(), isAI };
    });

    // Metrics
    const readabilityScore = Math.round(Math.min(100, 50 + contractions * 5 + (hasFirstPerson ? 20 : 0) - repScore * 5));
    const naturalnessScore = Math.round(100 - aiScore * 0.8);
    const engagementScore = Math.round(Math.min(100, readabilityScore * 0.7 + contractions * 8 + (hasFirstPerson ? 15 : 0)));

    return {
      aiScore, humanScore,
      metrics: {
        'Sentence Variation Score': variationScore,
        'Readability Score': readabilityScore,
        'Naturalness Score': naturalnessScore,
        'Repetition Score': repetitionScore,
        'Engagement Score': engagementScore
      },
      classifiedSentences,
      recommendations: buildRecommendations(signals, variationScore, readabilityScore, contractions)
    };
  }

  function buildRecommendations(signals, varScore, readScore, contractions) {
    const recs = [];
    if (signals.includes('low_variation'))
      recs.push({ icon:'📝', text:'Increase sentence variation — mix short punchy sentences with longer detailed ones.' });
    if (contractions < 2)
      recs.push({ icon:'📌’¬', text:'Add contractions (don\'t, I\'ve, you\'re) to sound more natural and conversational.' });
    if (signals.includes('formal_phrases'))
      recs.push({ icon:'âœ‚️', text:'Remove formal AI phrases like "furthermore", "it is important to note", "utilize".' });
    if (signals.includes('repetition'))
      recs.push({ icon:'🔍„', text:'Reduce repetitive phrasing — vary your word choice and avoid reusing the same terms.' });
    if (readScore < 60)
      recs.push({ icon:'📝–', text:'Improve readability — use simpler words, shorter paragraphs, and active voice.' });
    recs.push({ icon:'👤¤', text:'Add personal examples, anecdotes, or first-person perspective (I, we, my).' });
    recs.push({ icon:'🎯', text:'Use the AI Humanizer tab to automatically apply all these improvements at once.' });
    return recs;
  }

  function renderDetectResults(result) {
    document.getElementById('detect-placeholder').style.display = 'none';
    document.getElementById('detect-results').classList.add('active');

    document.getElementById('ai-pct').textContent = result.aiScore + '%';
    document.getElementById('human-pct').textContent = result.humanScore + '%';

    // Verdict
    const v = document.getElementById('detect-verdict');
    if (result.aiScore >= 70) {
      v.className = 'aih-verdict likely-ai';
      v.innerHTML = '🤖 Verdict: This content is <strong>likely AI-generated</strong>. Use the Humanizer to fix this.';
    } else if (result.aiScore >= 40) {
      v.className = 'aih-verdict mixed';
      v.innerHTML = '🔍€ Verdict: This content is <strong>mixed</strong> — partially AI, partially human.';
    } else {
      v.className = 'aih-verdict likely-human';
      v.innerHTML = '✅ Verdict: This content appears to be <strong>naturally human-written</strong>.';
    }

    // Metrics
    const metricColors = {
      'Sentence Variation Score': '#6366f1',
      'Readability Score': '#06b6d4',
      'Naturalness Score': '#10b981',
      'Repetition Score': '#f59e0b',
      'Engagement Score': '#ec4899'
    };
    document.getElementById('detect-metrics').innerHTML = Object.entries(result.metrics).map(([k, v]) => `
      <div class="aih-metric">
        <span class="aih-metric-label">${k}</span>
        <div class="aih-metric-bar">
          <div class="aih-metric-fill" style="width:${v}%;background:${metricColors[k]||'#6366f1'};"></div>
        </div>
        <span class="aih-metric-val">${v}/100</span>
      </div>
    `).join('');

    // Sentence highlights
    document.getElementById('sentence-highlights').innerHTML = result.classifiedSentences.map(s =>
      `<span class="aih-sentence ${s.isAI ? 'ai-flag' : 'human-flag'}">${s.text} </span>`
    ).join(' ');

    // Recommendations
    document.getElementById('detect-recs').innerHTML = result.recommendations.map(r =>
      `<div class="aih-rec-item"><span class="aih-rec-icon">${r.icon}</span><span>${r.text}</span></div>`
    ).join('');
  }

  document.getElementById('detect-btn').addEventListener('click', () => {
    const text = document.getElementById('detect-input').value.trim();
    if (text.length < 50) { showToast('Please enter at least 50 characters.'); return; }

    detectInput = text;
    document.getElementById('detect-btn').disabled = true;
    document.getElementById('detect-loading').classList.add('active');
    document.getElementById('detect-results').classList.remove('active');
    document.getElementById('detect-placeholder').style.display = 'none';

    runLoader(DETECT_MSGS, 'detect-bar', 'detect-msg', 5000, () => {
      document.getElementById('detect-loading').classList.remove('active');
      document.getElementById('detect-btn').disabled = false;
      detectResult = analyzeAI(text);
      renderDetectResults(detectResult);
    });
  });

  // Detect export
  document.getElementById('det-copy-report').addEventListener('click', () => {
    if (!detectResult) return;
    let txt = `AI CONTENT ANALYSIS REPORT\n${'='.repeat(35)}\n\n`;
    txt += `AI Likelihood: ${detectResult.aiScore}%\nHuman Likelihood: ${detectResult.humanScore}%\n\n`;
    txt += `METRICS\n${'-'.repeat(25)}\n`;
    Object.entries(detectResult.metrics).forEach(([k,v]) => txt += `${k}: ${v}/100\n`);
    txt += `\nRECOMMENDATIONS\n${'-'.repeat(25)}\n`;
    detectResult.recommendations.forEach(r => txt += `${r.icon} ${r.text}\n`);
    copyText(txt);
  });

  document.getElementById('det-export-txt').addEventListener('click', () => {
    if (!detectResult) return;
    let txt = `AI CONTENT ANALYSIS REPORT\n${'='.repeat(35)}\n\n`;
    txt += `AI Likelihood: ${detectResult.aiScore}%\nHuman Likelihood: ${detectResult.humanScore}%\n\n`;
    Object.entries(detectResult.metrics).forEach(([k,v]) => txt += `${k}: ${v}/100\n`);
    downloadFile(txt, 'ai-detection-report.txt', 'text/plain');
  });

  document.getElementById('det-export-pdf').addEventListener('click', () => {
    if (!detectResult) { showToast('Run the analysis first.'); return; }
    window.print();
    showToast('Use browser Print → Save as PDF');
  });

  // ================================================================
  //  TOOL 2: HUMANIZER
  // ================================================================

  function humanizeText(text, style, level) {
    // Smart text transformation engine
    const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];

    // Style configurations
    const styleConfig = {
      professional: { contractions: false, personal: false, casual: false },
      casual:        { contractions: true,  personal: true,  casual: true  },
      blogger:       { contractions: true,  personal: true,  casual: false },
      marketing:     { contractions: true,  personal: false, casual: false },
      storytelling:  { contractions: true,  personal: true,  casual: true  },
      educational:   { contractions: false, personal: false, casual: false }
    };
    const cfg = styleConfig[style] || styleConfig.blogger;

    // Replacements for robotic AI words
    const replacements = [
      [/\butilize\b/gi, 'use'],
      [/\bleverage\b/gi, 'use'],
      [/\bfurthermore\b/gi, 'also'],
      [/\bmoreover\b/gi, 'plus'],
      [/\bin conclusion\b/gi, 'to wrap things up'],
      [/\bit is important to note\b/gi, 'keep in mind'],
      [/\bit should be noted\b/gi, 'worth noting'],
      [/\bin addition\b/gi, 'on top of that'],
      [/\bconsequently\b/gi, 'as a result'],
      [/\bdelve into\b/gi, 'explore'],
      [/\bstreamline\b/gi, 'simplify'],
      [/\bensure\b/gi, 'make sure'],
      [/\bfacilitate\b/gi, 'help'],
      [/\bdemonstrate\b/gi, 'show'],
      [/\bcommence\b/gi, 'start'],
      [/\btherefore\b/gi, 'so'],
      [/\bthus\b/gi, 'so'],
    ];

    const levelIntensity = { light: 0.4, medium: 0.7, strong: 1.0 }[level] || 0.7;

    // Personal openers for blogger/casual style
    const openers = [
      "Here's the thing — ", "Let me be honest: ", "This is something I've seen a lot: ",
      "And this is where it gets interesting — ", "Here's what most people miss: ",
      "Think about it this way: ", "Real talk: "
    ];

    let result = sentences.map((sentence, i) => {
      let s = sentence.trim();

      // Apply replacements
      replacements.forEach(([pattern, replacement]) => {
        s = s.replace(pattern, replacement);
      });

      // Add contractions for casual styles
      if (cfg.contractions && Math.random() < levelIntensity) {
        s = s.replace(/\bdo not\b/gi, "don't")
             .replace(/\bcannot\b/gi, "can't")
             .replace(/\bwill not\b/gi, "won't")
             .replace(/\bis not\b/gi, "isn't")
             .replace(/\bare not\b/gi, "aren't")
             .replace(/\bit is\b/gi, "it's")
             .replace(/\bI am\b/g, "I'm")
             .replace(/\bthey are\b/gi, "they're");
      }

      // Vary sentence starters occasionally
      if (cfg.personal && i > 0 && i % 4 === 0 && Math.random() < levelIntensity * 0.5) {
        s = openers[i % openers.length] + s.charAt(0).toLowerCase() + s.slice(1);
      }

      // Break very long sentences at 'and' or 'but' for strong level
      if (level === 'strong' && s.split(' ').length > 30) {
        s = s.replace(/,\s+(and|but|so)\s+/i, (m, conj) => `. ${conj.charAt(0).toUpperCase()}${conj.slice(1)} `);
      }

      return s;
    });

    // Add paragraph breaks for readability
    if (levelIntensity > 0.5) {
      const grouped = [];
      for (let i = 0; i < result.length; i += 3) {
        grouped.push(result.slice(i, i + 3).join(' '));
      }
      return grouped.join('\n\n');
    }

    return result.join(' ');
  }

  document.getElementById('humanize-btn').addEventListener('click', () => {
    const text = document.getElementById('humanize-input').value.trim();
    if (text.length < 50) { showToast('Please enter at least 50 characters.'); return; }

    const style = document.getElementById('hum-style').value;
    const level = document.getElementById('hum-level').value;
    const btn = document.getElementById('humanize-btn');
    const inputEl = document.getElementById('humanize-input');
    const prompt = `Rewrite the following text in a ${style} style with ${level} humanization level. Make it sound completely natural and human-written. Remove all AI patterns like 'furthermore', 'moreover', 'it is important to note'. Add contractions, vary sentence lengths, and use conversational language:\n\n${text}`;

    document.getElementById('humanize-loading').classList.add('active');
    document.getElementById('humanize-results').classList.remove('active');
    document.getElementById('humanize-placeholder').style.display = 'none';

    window.executeSaaSAction(btn, 'ai-humanizer', inputEl, function(html, source) {
      document.getElementById('humanize-loading').classList.remove('active');

      if (source === 'api') {
        humanizeResult = html.replace(/<[^>]*>/g, '').trim();
      } else {
        humanizeResult = humanizeText(text, style, level);
      }

      const levelMap = { light: ['+12%','+15%','+10%'], medium: ['+28%','+34%','+25%'], strong: ['+48%','+52%','+44%'] };
      const improvements = levelMap[level];
      document.getElementById('humanize-badges').innerHTML = [
        `📖 Readability ${improvements[0]}`,
        `🌿 Naturalness ${improvements[1]}`,
        `💡 Engagement ${improvements[2]}`
      ].map(b => `<div class="aih-improve-badge">✅ ${b}${source === 'api' ? ' 🤖' : ''}</div>`).join('');

      document.getElementById('humanize-output').textContent = humanizeResult;
      document.getElementById('humanize-results').classList.add('active');
      document.getElementById('humanize-placeholder').style.display = 'none';
    });
  });

  document.getElementById('hum-copy').addEventListener('click', () => { if(humanizeResult) copyText(humanizeResult); });
  document.getElementById('hum-copy-all').addEventListener('click', () => { if(humanizeResult) copyText(humanizeResult); });
  document.getElementById('hum-txt').addEventListener('click', () => { if(humanizeResult) downloadFile(humanizeResult, 'humanized-content.txt', 'text/plain'); });
  document.getElementById('hum-pdf').addEventListener('click', () => { showToast('Use browser Print → Save as PDF'); window.print(); });

  // ================================================================
  //  TOOL 3: BEFORE vs AFTER
  // ================================================================

  function populateCompare() {
    const originalText = document.getElementById('detect-input').value.trim() ||
                         document.getElementById('humanize-input').value.trim();
    const humanizedText = humanizeResult;

    if (!originalText || !humanizedText) return;

    document.getElementById('compare-placeholder').style.display = 'none';
    document.getElementById('compare-results').classList.add('active');

    document.getElementById('compare-before-text').textContent = originalText.slice(0, 600) + (originalText.length > 600 ? '...' : '');
    document.getElementById('compare-after-text').textContent = humanizedText.slice(0, 600) + (humanizedText.length > 600 ? '...' : '');

    const beforeAnalysis = detectResult || analyzeAI(originalText);
    const afterHumanScore = Math.min(95, beforeAnalysis.humanScore + 30);
    const afterReadability = Math.min(100, (beforeAnalysis.metrics['Readability Score'] || 50) + 25);
    const afterNaturalness = Math.min(100, (beforeAnalysis.metrics['Naturalness Score'] || 40) + 32);
    const afterEngagement  = Math.min(100, (beforeAnalysis.metrics['Engagement Score'] || 40) + 28);

    document.getElementById('compare-scores').innerHTML = [
      { label: 'Readability', before: beforeAnalysis.metrics['Readability Score'], after: afterReadability },
      { label: 'Naturalness', before: beforeAnalysis.metrics['Naturalness Score'], after: afterNaturalness },
      { label: 'Engagement',  before: beforeAnalysis.metrics['Engagement Score'],  after: afterEngagement  },
      { label: 'Human Score', before: beforeAnalysis.humanScore, after: afterHumanScore }
    ].map(m => `
      <div class="compare-score-card">
        <h4>${m.label}</h4>
        <div class="compare-before-val">${m.before}/100</div>
        <div class="compare-arrow">←“</div>
        <div class="compare-after-val">${m.after}/100</div>
        <div class="compare-delta">+${m.after - m.before} pts</div>
      </div>
    `).join('');
  }

  document.getElementById('cmp-copy-after').addEventListener('click', () => { if(humanizeResult) copyText(humanizeResult); });
  document.getElementById('cmp-txt').addEventListener('click', () => {
    if (!humanizeResult) return;
    const orig = document.getElementById('detect-input').value.trim() || document.getElementById('humanize-input').value.trim();
    downloadFile(`ORIGINAL\n${'='.repeat(30)}\n${orig}\n\nHUMANIZED\n${'='.repeat(30)}\n${humanizeResult}`, 'comparison.txt', 'text/plain');
  });

  // ================================================================
  //  TOOL 4: SEO HUMANIZER
  // ================================================================

  document.getElementById('seo-btn').addEventListener('click', () => {
    const text = document.getElementById('seo-input').value.trim();
    const keyword = document.getElementById('seo-keyword').value.trim();
    if (text.length < 100) { showToast('Please enter at least 100 characters.'); return; }

    const btn = document.getElementById('seo-btn');
    const inputEl = document.getElementById('seo-input');
    const prompt = `Humanize the following AI-generated article for SEO. Focus keyword: "${keyword || 'content'}". Make it sound natural, human-written, and engaging while:\n1. Preserving all SEO keywords naturally in the text\n2. Improving headings structure (H1, H2, H3)\n3. Removing robotic AI phrases\n4. Adding conversational tone and flow\n\nArticle:\n${text}`;

    document.getElementById('seo-loading').classList.add('active');
    document.getElementById('seo-results').classList.remove('active');
    document.getElementById('seo-placeholder').style.display = 'none';

    window.executeSaaSAction(btn, 'seo-humanizer', inputEl, function(html, source) {
      document.getElementById('seo-loading').classList.remove('active');

      const humanized = source === 'api'
        ? html.replace(/<[^>]*>/g, '').trim()
        : humanizeText(text, 'blogger', 'medium');

      const headings = [
        { tag: 'H1', text: (keyword ? keyword.charAt(0).toUpperCase() + keyword.slice(1) + ': ' : '') + 'The Complete Guide' },
        { tag: 'H2', text: 'What You Need to Know First' },
        { tag: 'H2', text: 'Step-by-Step Breakdown' },
        { tag: 'H3', text: 'Common Mistakes to Avoid' },
        { tag: 'H2', text: 'Expert Tips for Better Results' },
        { tag: 'H2', text: 'Conclusion' }
      ];

      const keywords = keyword
        ? [keyword, `best ${keyword}`, `${keyword} guide`, `${keyword} tips`, `${keyword} 2026`]
        : ['content optimization', 'SEO strategy', 'readability score', 'engagement rate', 'keyword density'];

      document.getElementById('seo-headings').innerHTML = headings.map(h =>
        `<div style="margin-bottom:8px;font-size:0.88rem;color:var(--text-secondary);">
          <span class="seo-heading-tag">${h.tag}</span>${h.text}
        </div>`
      ).join('');

      document.getElementById('seo-keywords').innerHTML = keywords.map(k =>
        `<span class="seo-keyword-chip">${k}</span>`
      ).join('');

      document.getElementById('seo-article').textContent = humanized + (source === 'api' ? '' : '');
      document.getElementById('seo-results').classList.add('active');
      showToast(source === 'api' ? '✅ Humanized with AI 🤖' : '✅ Humanized (demo mode)');
    }, prompt);
  });

  document.getElementById('seo-copy').addEventListener('click', () => {
    const txt = document.getElementById('seo-article').textContent;
    if (txt) copyText(txt);
  });
  document.getElementById('seo-txt').addEventListener('click', () => {
    const txt = document.getElementById('seo-article').textContent;
    if (txt) downloadFile(txt, 'seo-humanized-article.txt', 'text/plain');
  });
  document.getElementById('seo-pdf').addEventListener('click', () => { showToast('Use browser Print → Save as PDF'); window.print(); });

  // Expose to global scope for onclick handlers
  window.switchTab = switchTab;
  </script>

