<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="AI Content Detector & Humanizer — Detect AI-generated text and rewrite it to sound natural, human, and engaging. Powered by OpenAI.">
  <meta name="keywords" content="AI content detector, AI humanizer, AI text rewriter, bypass AI detection, humanize AI text, Chafiktech Ai">
  <title>AI Content Detector & Humanizer — Chafiktech Ai</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../css/style.css">
  <style>
    /* =============================================
       AI Content Detector & Humanizer — Styles
       ============================================= */

    /* Page Hero */
    .aih-hero {
      padding: 140px 0 70px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .aih-hero::before {
      content: '';
      position: absolute; top: -200px; left: 50%;
      transform: translateX(-50%);
      width: 1000px; height: 900px;
      background: radial-gradient(circle, rgba(99,102,241,0.14) 0%, rgba(168,85,247,0.08) 40%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }
    .aih-hero::after {
      content: '';
      position: absolute; bottom: -20%; right: -5%;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(6,182,212,0.07) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }
    .aih-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 18px;
      background: rgba(99,102,241,0.1);
      border: 1px solid rgba(99,102,241,0.3);
      border-radius: 999px;
      font-size: 0.8rem; color: #818cf8; font-weight: 600;
      margin-bottom: 24px; letter-spacing: 0.04em;
    }
    .aih-badge .dot { width:8px; height:8px; background:#818cf8; border-radius:50%; animation: pulse-dot 1.8s infinite; }
    .aih-hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3.6rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 20px;
    }
    .aih-hero h1 .grad {
      background: linear-gradient(135deg, #6366f1, #a855f7, #06b6d4);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .aih-hero p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px; margin: 0 auto 48px;
      line-height: 1.75;
    }

    /* Stats */
    .aih-stats { display: flex; justify-content: center; gap: 56px; flex-wrap: wrap; margin-bottom: 24px; }
    .aih-stat { text-align: center; }
    .aih-stat-val {
      font-family: var(--font-display); font-size: 2rem; font-weight: 700;
      background: linear-gradient(135deg, #6366f1, #06b6d4);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .aih-stat-lbl { font-size: 0.78rem; color: var(--text-tertiary); margin-top: 4px; }

    /* Tab Navigation */
    .aih-tabs {
      display: flex; gap: 4px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 6px;
      max-width: 700px;
      margin: 0 auto 48px;
      flex-wrap: wrap;
    }
    .aih-tab {
      flex: 1; min-width: 140px;
      padding: 11px 18px;
      border-radius: 11px;
      border: none;
      background: transparent;
      color: var(--text-secondary);
      font-size: 0.85rem; font-weight: 600;
      font-family: var(--font-sans);
      cursor: pointer;
      transition: all 0.22s;
      text-align: center;
      white-space: nowrap;
    }
    .aih-tab.active {
      background: rgba(99,102,241,0.2);
      border: 1px solid rgba(99,102,241,0.35);
      color: #a5b4fc;
    }
    .aih-tab:hover:not(.active) { background: rgba(255,255,255,0.05); color: var(--text-primary); }

    /* Panel */
    .aih-panel { display: none; animation: fadeInUp 0.35s ease both; }
    .aih-panel.active { display: block; }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Two-col Layout */
    .aih-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      align-items: start;
    }
    @media(max-width:900px) { .aih-layout { grid-template-columns: 1fr; } }

    /* Card */
    .aih-card {
      background: rgba(255,255,255,0.04);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 24px;
      padding: 32px;
    }
    .aih-card-title {
      font-family: var(--font-display);
      font-size: 1.15rem; font-weight: 700;
      margin-bottom: 6px;
      display: flex; align-items: center; gap: 10px;
    }
    .aih-card-sub { font-size: 0.84rem; color: var(--text-secondary); margin-bottom: 24px; line-height: 1.5; }

    /* Textarea */
    .aih-textarea {
      width: 100%;
      background: rgba(0,0,0,0.3);
      border: 1px solid rgba(255,255,255,0.09);
      border-radius: 14px;
      padding: 16px 18px;
      font-family: var(--font-sans); font-size: 0.9rem;
      color: var(--text-primary);
      resize: vertical; min-height: 240px;
      line-height: 1.7;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .aih-textarea:focus {
      outline: none;
      border-color: rgba(99,102,241,0.5);
      box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
    }
    .aih-textarea::placeholder { color: var(--text-muted); }

    .aih-char-count {
      text-align: right; font-size: 0.75rem;
      color: var(--text-muted); margin-top: 6px;
    }

    /* Settings Row */
    .aih-settings-row { display: flex; gap: 12px; flex-wrap: wrap; margin: 16px 0; }
    .aih-select-label {
      font-size: 0.78rem; font-weight: 600;
      color: var(--text-tertiary); text-transform: uppercase;
      letter-spacing: 0.07em; margin-bottom: 6px;
    }
    .aih-select {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px; padding: 9px 14px;
      color: var(--text-primary); font-family: var(--font-sans);
      font-size: 0.84rem; cursor: pointer;
      transition: border-color 0.2s;
    }
    .aih-select:focus { outline: none; border-color: rgba(99,102,241,0.5); }

    /* Generate Btn */
    .aih-gen-btn {
      width: 100%; margin-top: 20px;
      padding: 15px;
      border-radius: 14px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6, #a855f7);
      color: #fff; font-weight: 700; font-size: 1rem;
      font-family: var(--font-display);
      cursor: pointer; border: none;
      transition: all 0.25s;
      box-shadow: 0 4px 20px rgba(99,102,241,0.35);
      display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .aih-gen-btn:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(99,102,241,0.5);
    }
    .aih-gen-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

    /* Loading */
    .aih-loading { display: none; flex-direction: column; align-items: center; gap: 18px; padding: 40px 0; }
    .aih-loading.active { display: flex; }
    .aih-loading-ring {
      width: 60px; height: 60px; border-radius: 50%;
      border: 3px solid rgba(255,255,255,0.06);
      border-top-color: #6366f1; border-right-color: #06b6d4;
      animation: spin 0.85s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .aih-progress-track {
      width: 100%; height: 4px;
      background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden;
    }
    .aih-progress-fill {
      height: 100%; width: 0%;
      background: linear-gradient(90deg, #6366f1, #a855f7, #06b6d4);
      border-radius: 2px; transition: width 0.5s ease;
    }
    .aih-loading-msg { font-size: 0.9rem; font-weight: 600; color: var(--text-secondary); }

    /* Results area */
    .aih-results { display: none; }
    .aih-results.active { display: block; }

    /* Score Circle */
    .aih-score-ring-wrap {
      display: flex; gap: 20px; flex-wrap: wrap;
      justify-content: center; margin-bottom: 28px;
    }
    .aih-score-circle {
      width: 120px; height: 120px;
      border-radius: 50%;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      border: 4px solid;
      position: relative;
    }
    .aih-score-circle.ai-score {
      border-color: #ef4444;
      box-shadow: 0 0 24px rgba(239,68,68,0.3);
      background: rgba(239,68,68,0.07);
    }
    .aih-score-circle.human-score {
      border-color: #10b981;
      box-shadow: 0 0 24px rgba(16,185,129,0.3);
      background: rgba(16,185,129,0.07);
    }
    .aih-score-num {
      font-family: var(--font-display); font-size: 1.9rem; font-weight: 800;
      line-height: 1;
    }
    .aih-score-circle.ai-score .aih-score-num { color: #f87171; }
    .aih-score-circle.human-score .aih-score-num { color: #34d399; }
    .aih-score-label { font-size: 0.7rem; font-weight: 600; color: var(--text-secondary); margin-top: 4px; text-align: center; line-height: 1.3; }

    /* Verdict badge */
    .aih-verdict {
      display: flex; align-items: center; justify-content: center;
      gap: 10px; padding: 13px 24px;
      border-radius: 14px;
      margin-bottom: 24px;
      font-weight: 700; font-size: 1rem;
    }
    .aih-verdict.likely-ai { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #f87171; }
    .aih-verdict.likely-human { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); color: #34d399; }
    .aih-verdict.mixed { background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.3); color: #fbbf24; }

    /* Metric bars */
    .aih-metric {
      display: flex; align-items: center; gap: 14px;
      margin-bottom: 14px;
    }
    .aih-metric-label { font-size: 0.82rem; font-weight: 600; color: var(--text-secondary); min-width: 150px; }
    .aih-metric-bar { flex: 1; height: 8px; background: rgba(255,255,255,0.07); border-radius: 4px; overflow: hidden; }
    .aih-metric-fill { height: 100%; border-radius: 4px; transition: width 1s ease; }
    .aih-metric-val { font-size: 0.82rem; font-weight: 700; color: var(--text-primary); min-width: 36px; text-align: right; }

    /* Highlighted sentences */
    .aih-sentences { margin: 20px 0; }
    .aih-sentence {
      display: inline; padding: 2px 0;
      border-radius: 3px;
      transition: background 0.2s;
    }
    .aih-sentence.ai-flag { background: rgba(239,68,68,0.18); border-bottom: 2px solid rgba(239,68,68,0.6); }
    .aih-sentence.human-flag { background: rgba(16,185,129,0.12); border-bottom: 2px solid rgba(16,185,129,0.4); }
    .sentence-container {
      background: rgba(0,0,0,0.25);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px; padding: 18px;
      font-size: 0.88rem; line-height: 2;
      color: var(--text-secondary);
    }
    .sentence-legend {
      display: flex; gap: 20px; flex-wrap: wrap;
      margin-bottom: 12px; font-size: 0.78rem; font-weight: 600;
    }
    .legend-item { display: flex; align-items: center; gap: 7px; }
    .legend-dot { width: 12px; height: 12px; border-radius: 3px; }
    .legend-dot.ai { background: rgba(239,68,68,0.5); }
    .legend-dot.human { background: rgba(16,185,129,0.4); }

    /* Recommendations */
    .aih-recs { margin-top: 20px; }
    .aih-rec-item {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 12px 14px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 10px; margin-bottom: 8px;
      font-size: 0.85rem; line-height: 1.5;
    }
    .aih-rec-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

    /* Humanized output */
    .aih-output-text {
      background: rgba(0,0,0,0.25);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px; padding: 20px;
      font-size: 0.9rem; line-height: 1.85;
      color: var(--text-secondary);
      white-space: pre-wrap;
      min-height: 200px;
    }

    /* Improvement badges */
    .aih-improvements {
      display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px;
    }
    .aih-improve-badge {
      display: flex; align-items: center; gap: 6px;
      padding: 7px 14px;
      background: rgba(16,185,129,0.1);
      border: 1px solid rgba(16,185,129,0.25);
      border-radius: 8px; font-size: 0.78rem; font-weight: 600;
      color: #34d399;
    }

    /* Export/Action buttons */
    .aih-action-row {
      display: flex; gap: 8px; flex-wrap: wrap; margin-top: 18px;
    }
    .aih-action-btn {
      padding: 9px 18px;
      border-radius: 10px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      color: var(--text-secondary);
      font-size: 0.82rem; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
      display: flex; align-items: center; gap: 6px;
    }
    .aih-action-btn:hover { background: rgba(255,255,255,0.12); color: var(--text-primary); }

    /* Before/After Comparison */
    .compare-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 20px; margin-bottom: 24px;
    }
    @media(max-width:768px) { .compare-grid { grid-template-columns: 1fr; } }
    .compare-panel {
      background: rgba(0,0,0,0.25);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px; padding: 20px;
    }
    .compare-panel-title {
      font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; margin-bottom: 14px;
      display: flex; align-items: center; gap: 8px;
    }
    .compare-panel.before .compare-panel-title { color: #f87171; }
    .compare-panel.after  .compare-panel-title { color: #34d399; }
    .compare-text {
      font-size: 0.87rem; line-height: 1.8;
      color: var(--text-secondary); white-space: pre-wrap;
    }
    .compare-scores {
      display: flex; gap: 14px; flex-wrap: wrap; margin-top: 24px;
    }
    .compare-score-card {
      flex: 1; min-width: 140px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px; padding: 16px;
      text-align: center;
    }
    .compare-score-card h4 { font-size: 0.78rem; color: var(--text-tertiary); margin-bottom: 10px; }
    .compare-before-val { font-size: 1.1rem; font-weight: 700; color: #f87171; }
    .compare-arrow { font-size: 1.2rem; margin: 4px 0; color: var(--text-tertiary); }
    .compare-after-val { font-size: 1.1rem; font-weight: 700; color: #34d399; }
    .compare-delta {
      display: inline-block; margin-top: 8px;
      padding: 2px 8px; border-radius: 6px;
      font-size: 0.72rem; font-weight: 700;
      background: rgba(16,185,129,0.15); color: #34d399;
    }

    /* SEO Humanizer */
    .seo-output-section { margin-top: 24px; }
    .seo-output-section h3 {
      font-size: 0.78rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--text-tertiary); margin-bottom: 12px;
      display: flex; align-items: center; gap: 8px;
    }
    .seo-heading-tag {
      display: inline-block;
      padding: 2px 8px; border-radius: 5px;
      background: rgba(99,102,241,0.15);
      border: 1px solid rgba(99,102,241,0.3);
      font-size: 0.72rem; font-weight: 700; color: #818cf8;
      margin-right: 8px; font-family: var(--font-mono, monospace);
    }
    .seo-keyword-chip {
      display: inline-block; padding: 4px 10px;
      background: rgba(6,182,212,0.1); border: 1px solid rgba(6,182,212,0.25);
      border-radius: 6px; font-size: 0.78rem; font-weight: 600;
      color: #22d3ee; margin: 3px;
    }

    /* Admin Settings */
    .admin-key-row {
      margin-bottom: 24px;
    }
    .admin-key-row label {
      display: block; font-size: 0.82rem; font-weight: 600;
      color: var(--text-secondary); margin-bottom: 10px;
      text-transform: uppercase; letter-spacing: 0.07em;
    }
    .admin-key-input-row { display: flex; gap: 10px; align-items: stretch; }
    .admin-key-input {
      flex: 1;
      background: rgba(0,0,0,0.35); border: 1px solid rgba(255,255,255,0.09);
      border-radius: 12px; padding: 12px 16px;
      font-family: var(--font-mono, monospace); font-size: 0.85rem;
      color: var(--text-primary); transition: border-color 0.2s;
    }
    .admin-key-input:focus { outline: none; border-color: rgba(99,102,241,0.5); }
    .admin-test-btn {
      padding: 12px 20px;
      background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px; color: var(--text-secondary); font-size: 0.82rem; font-weight: 600;
      cursor: pointer; transition: all 0.2s; white-space: nowrap;
    }
    .admin-test-btn:hover { background: rgba(255,255,255,0.13); color: var(--text-primary); }
    .admin-del-btn {
      padding: 12px 14px;
      background: rgba(239,68,68,0.07); border: 1px solid rgba(239,68,68,0.2);
      border-radius: 12px; color: #f87171; font-size: 0.85rem;
      cursor: pointer; transition: all 0.2s;
    }
    .admin-del-btn:hover { background: rgba(239,68,68,0.15); }
    .admin-status {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 5px 12px; border-radius: 7px;
      font-size: 0.78rem; font-weight: 700; margin-top: 10px;
    }
    .admin-status.connected { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); color: #34d399; }
    .admin-status.missing   { background: rgba(100,116,139,0.12); border: 1px solid rgba(100,116,139,0.3); color: #94a3b8; }
    .admin-status.invalid   { background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.3); color: #fbbf24; }
    .admin-save-btn {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      width: 100%; padding: 14px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      border: none; border-radius: 14px;
      color: #fff; font-weight: 700; font-size: 0.95rem;
      font-family: var(--font-display);
      cursor: pointer; transition: all 0.25s;
      box-shadow: 0 4px 20px rgba(99,102,241,0.3);
      margin-top: 10px;
    }
    .admin-save-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(99,102,241,0.5); }

    /* Section divider */
    .aih-divider {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.07);
      margin: 28px 0;
    }
    .aih-section-label {
      font-size: 0.78rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--text-tertiary); margin-bottom: 14px;
    }

    /* Toast */
    .aih-toast {
      position: fixed; bottom: 28px; right: 28px; z-index: 9999;
      background: #13131f; border: 1px solid rgba(99,102,241,0.4);
      border-radius: 12px; padding: 12px 22px;
      font-size: 0.875rem; font-weight: 600; color: #fff;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      display: flex; align-items: center; gap: 10px;
      transform: translateY(80px); opacity: 0;
      transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1);
    }
    .aih-toast.show { transform: translateY(0); opacity: 1; }

    /* Responsive */
    @media(max-width:640px) {
      .aih-tabs { flex-direction: column; }
      .aih-tab { min-width: unset; }
      .aih-score-ring-wrap { gap: 12px; }
      .aih-score-circle { width: 100px; height: 100px; }
      .aih-score-num { font-size: 1.5rem; }
    }
  
    /* Navbar Dropdown styling */
    .nav-dropdown { position: relative; display: inline-block; }
    .dropdown-content { display: none; position: absolute; top: 100%; left: 0; background: var(--bg2); min-width: 240px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); border: 1px solid var(--border); border-radius: 10px; padding: 10px 0; z-index: 1000; }
    .nav-dropdown:hover .dropdown-content { display: flex; flex-direction: column; }
    .dropdown-content a { color: var(--text); padding: 12px 20px; text-decoration: none; font-size: 0.88rem; font-weight: 500; transition: background 0.2s, padding-left 0.2s; font-family: var(--font, sans-serif); }
    .dropdown-content a:hover { background: var(--glass2, rgba(255,255,255,0.08)); padding-left: 24px; color: var(--indigo2, #818cf8); }

  </style>
</head>
<body class="bg-mesh">

  
    <!-- Navbar -->
    <nav class="navbar" id="navbar">
        <div class="container nav-inner">
            <a href="../index.html" class="nav-logo">
                <div class="nav-logo-icon">⚡</div>
                Chafiktech Ai
            </a>
            <div class="nav-links">
                <a href="../index.html" class="nav-link">Home</a>
                <div class="nav-dropdown">
